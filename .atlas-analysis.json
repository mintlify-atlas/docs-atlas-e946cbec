  "keyFeatures": [
    "Multi-company orchestration with complete data isolation",
    "Hierarchical org chart with agent reporting structure",
    "Atomic task checkout and status transitions",
    "Budget tracking with hard-stop enforcement",
    "Governance and approval workflows",
    "Heartbeat-based agent invocation",
    "Process and HTTP adapters for agent integration",
    "Cost event tracking and rollups",
    "Activity audit logging",
    "CLI for setup and diagnostics"
  ],
  "publicApiSurface": [
    "GET /api/companies",
    "POST /api/companies",
    "GET /api/companies/:companyId/agents",
